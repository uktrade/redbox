    "    \"    \\\"   \\\\\\\"outputs\\\\\\\": [],\\\\n\\\",\\n\",\n",
    "    \"    \\\"   \\\\\\\"source\\\\\\\": [\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"from langchain_core.messages import AIMessage\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"from redbox.models.chain import RedboxQuery, RedboxState, AISettings, configure_agent_task_plan\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"from uuid import uuid4\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"state = RedboxState(\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"    request=RedboxQuery(\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        question=\\\\\\\\\\\\\\\"tell me about cobalt company\\\\\\\\\\\\\\\",\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        s3_keys=[],\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        user_uuid=uuid4(),\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        chat_history=[],\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        ai_settings=AISettings(),\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        permitted_s3_keys=[],\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        sso_access_token=None,\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"    )\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\")\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"agent_options = {agent.name: agent.name for agent in AISettings().worker_agents}\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"agent_task, multi_agent_plan = configure_agent_task_plan(agent_options)\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"tasks = [agent_task(task=\\\\\\\\\\\\\\\"Get Some company details\\\\\\\\\\\\\\\", expected_output=\\\\\\\\\\\\\\\"company information\\\\\\\\\\\\\\\", agent=\\\\\\\\\\\\\\\"Datahub_Agent\\\\\\\\\\\\\\\")]\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"state.messages = [AIMessage(content=tasks[0].model_dump_json())]\\\\\\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"   ]\\\\n\\\",\\n\",\n",
    "    \"    \\\"  },\\\\n\\\",\\n\",\n",
    "    \"    \\\"  {\\\\n\\\",\\n\",\n",
    "    \"    \\\"   \\\\\\\"cell_type\\\\\\\": \\\\\\\"code\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"   \\\\\\\"execution_count\\\\\\\": null,\\\\n\\\",\\n\",\n",
    "    \"    \\\"   \\\\\\\"id\\\\\\\": \\\\\\\"2\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"   \\\\\\\"metadata\\\\\\\": {},\\\\n\\\",\\n\",\n",
    "    \"    \\\"   \\\\\\\"outputs\\\\\\\": [],\\\\n\\\",\\n\",\n",
    "    \"    \\\"   \\\\\\\"source\\\\\\\": [\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"state.messages\\\\\\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"   ]\\\\n\\\",\\n\",\n",
    "    \"    \\\"  },\\\\n\\\",\\n\",\n",
    "    \"    \\\"  {\\\\n\\\",\\n\",\n",
    "    \"    \\\"   \\\\\\\"cell_type\\\\\\\": \\\\\\\"code\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"   \\\\\\\"execution_count\\\\\\\": null,\\\\n\\\",\\n\",\n",
    "    \"    \\\"   \\\\\\\"id\\\\\\\": \\\\\\\"3\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"   \\\\\\\"metadata\\\\\\\": {},\\\\n\\\",\\n\",\n",
    "    \"    \\\"   \\\\\\\"outputs\\\\\\\": [],\\\\n\\\",\\n\",\n",
    "    \"    \\\"   \\\\\\\"source\\\\\\\": [\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"from mcp import ClientSession\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"from mcp.client.streamable_http import streamablehttp_client\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"from langchain_mcp_adapters.tools import load_mcp_tools\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"from redbox.graph.agents.configs import agent_configs\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"from redbox.models.settings import get_settings\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"from redbox.models.chain import ChatLLMBackend\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"from redbox.graph.nodes.processes import build_agent_with_loop\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"from redbox.graph.nodes.tools import get_datahub_mcp_tools\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"mcp_settings = get_settings().datahub_mcp\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"datahub_mcp_url = mcp_settings.url\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"async with streamablehttp_client(datahub_mcp_url) as (read, write, _), ClientSession(read, write) as session:\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"    # Initialize the connection\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"    await session.initialize()\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"    # Get tools\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"    tools = await load_mcp_tools(session)\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"    # adding URL metadata so that the agent can execute the tool later\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"    for tool in tools:\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        tool.metadata = {\\\\\\\\\\\\\\\"url\\\\\\\\\\\\\\\": datahub_mcp_url}\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"    # print(await tools[1].ainvoke({\\\\\\\\\\\\\\\"company_name\\\\\\\\\\\\\\\": 'BMW'}))\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"    # print(asyncio.run(tools[1].ainvoke({\\\\\\\\\\\\\\\"company_name\\\\\\\\\\\\\\\": 'SOME'})))\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"    config = agent_configs[\\\\\\\\\\\\\\\"Datahub_Agent\\\\\\\\\\\\\\\"]\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"    datahub_mcp = get_datahub_mcp_tools()\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"    agent_configs[\\\\\\\\\\\\\\\"Datahub_Agent\\\\\\\\\\\\\\\"].tools = datahub_mcp\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"    result = build_agent_with_loop(\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        agent_name=config.name,\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        system_prompt=config.prompt.system,\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        tools=config.tools,\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        max_tokens=config.agents_max_tokens,\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        loop_condition=lambda: True,\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        max_attempt=2,\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        use_metadata=False,\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        using_chat_history=True,\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"        model=ChatLLMBackend(name=\\\\\\\\\\\\\\\"anthropic.claude-3-7-sonnet-20250219-v1:0\\\\\\\\\\\\\\\", provider=\\\\\\\\\\\\\\\"bedrock\\\\\\\\\\\\\\\"),\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"    ).invoke(state)\\\\\\\\n\\\\\\\",\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"result\\\\\\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"   ]\\\\n\\\",\\n\",\n",
    "    \"    \\\"  }\\\\n\\\",\\n\",\n",
    "    \"    \\\" ],\\\\n\\\",\\n\",\n",
